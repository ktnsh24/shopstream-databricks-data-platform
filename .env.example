# =============================================================================
# Helix Data Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# --- Azure ---
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_CLIENT_ID=<service-principal-client-id>
AZURE_CLIENT_SECRET=<service-principal-client-secret>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=helix-data-rg

# --- Azure Storage (ADLS Gen2) ---
# This is where your raw files land (Auto Loader reads from here).
# Created by: terraform/azure/storage.tf
ADLS_ACCOUNT_NAME=helixdataadls
ADLS_CONTAINER_NAME=helix-lake

# --- Azure Event Hubs ---
# Orders stream — used in Lab DP-02 (streaming ingest).
EVENT_HUBS_NAMESPACE=helix-data-eventhubs
EVENT_HUBS_NAME=orders-stream
EVENT_HUBS_CONNECTION_STRING=<from-azure-key-vault>

# --- Azure Key Vault ---
KEY_VAULT_NAME=helix-data-kv
KEY_VAULT_URI=https://helix-data-kv.vault.azure.net/

# --- Databricks ---
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<personal-access-token-from-databricks-ui>
DATABRICKS_CLUSTER_ID=<your-cluster-id>
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>

# --- Unity Catalog ---
# These catalogs are created by terraform/databricks/unity_catalog.tf
# Use the SAME names as helix-ai-platform — this is intentional.
# When you finish your Gold tables, the AI platform can read from them directly.
UNITY_CATALOG_METASTORE_ID=<your-metastore-id>
UC_CATALOG_BRONZE=helix_bronze
UC_CATALOG_SILVER=helix_silver
UC_CATALOG_GOLD=helix_gold

# --- Lakeflow Connect ---
# Created once in Databricks workspace UI (Catalog > External Data > Connections)
# then referenced by data_platform/ingestion/*.yml
LAKEFLOW_GATEWAY_ID=<lakeflow-connect-gateway-id>

# --- Notification ---
ALERT_EMAIL=<your-email>

# --- Hands-on labs: config-tuning knobs ---
# Change these to see how they affect pipeline behaviour in the labs.
BRONZE_BATCH_TRIGGER_INTERVAL=60s
STREAMING_WATERMARK_DELAY=10 minutes
OPTIMIZE_ZORDER_COLUMNS=order_date,customer_id
AUTO_BROADCAST_JOIN_THRESHOLD_MB=10
